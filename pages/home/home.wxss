/* 试点迁移: 全量使用 design-token.wxss 令牌，单位统一 rpx。
   颜色 → 语义令牌；圆角/字号/字重 → 令牌；间距在刻度上用令牌，
   不在 4 倍数刻度上的 (6/10/14/18px) 暂保留字面 rpx 以零视觉差异。 */

.home-page {
  padding: var(--sp-5) var(--sp-4);            /* 20px 16px */
}

.home-hero {
  text-align: center;
  padding: var(--sp-6) 0 36rpx;                /* 24px 0 18px */
}

.home-title {
  display: block;
  font-size: var(--fs-display);                /* 28px */
  font-weight: var(--fw-bold);
  color: var(--c-title);                       /* #1f2d2a */
}

.home-desc {
  display: block;
  margin-top: 12rpx;                           /* 6px */
  font-size: var(--fs-body-sm);                /* 12px */
  color: var(--c-sub);                         /* #7a8581 */
}

.predict-card,
.result-card,
.guide-card {
  background: var(--c-card);                   /* #fff */
  border-radius: var(--radius-card-main);      /* 主卡层 */
  padding: var(--pad-card-main);               /* 20px */
  border: var(--border-1) solid var(--c-line-soft);
  box-shadow: var(--shadow-card-up);           /* 补阴影,与 .card 一致 */
  margin-bottom: 28rpx;                        /* 14px */
}

.field-label {
  display: block;
  font-size: var(--fs-body-sm);                /* 12px */
  font-weight: var(--fw-semibold);
  color: var(--c-body-2);                      /* #5d6965 */
  margin-bottom: var(--sp-2);                  /* 8px */
}

.field-label-gap {
  margin-top: 36rpx;                           /* 18px */
}

.gpa-input {
  display: block;
  width: 100%;
  height: var(--height-field);
  line-height: var(--height-field);
  padding: 0 var(--sp-3);
  box-sizing: border-box;
  border: var(--border-1) solid var(--c-line-faint);
  border-radius: var(--radius-field);
  font-size: var(--fs-subtitle);
  background: var(--c-card);
}

.major-row {
  display: flex;
  gap: 20rpx;                                  /* 10px */
}

.major-btn {
  flex: 1;
  padding: var(--sp-3) 0;                      /* 12px 0 */
  text-align: center;
  border: var(--border-1) solid var(--c-line-faint);
  border-radius: var(--radius-lg);             /* 10px */
  font-size: var(--fs-body);                   /* 13px */
  color: var(--c-body-2);
  background: var(--c-card);
}

.major-active {
  background: var(--gg-green-100);             /* #e8f0ed 精确匹配 */
  color: var(--c-primary);                     /* #2e5d50 */
  border-color: var(--c-primary);
  font-weight: var(--fw-semibold);
}

.predict-btn,
.match-btn,
.guide-btn {
  margin-top: var(--sp-5);                     /* 20px */
  width: 100%;
  height: 88rpx;                               /* 44px */
  line-height: 88rpx;
  background: var(--c-primary);
  color: var(--gg-white);                      /* #fff */
  border-radius: var(--radius-lg);             /* 10px */
  font-size: var(--fs-body-lg);                /* 15px */
  font-weight: var(--fw-semibold);
  padding: 0;
  border: 0;
}

.predict-btn::after,
.match-btn::after,
.guide-btn::after {
  border: none;
}

.match-btn {
  background: var(--gg-green-050);             /* #eef4f1 */
  color: var(--c-primary);
}

.guide-card {
  text-align: center;
  border: var(--border-2) dashed var(--c-cta-deco); /* 2px #c98a4b 虚线框 */
}

.guide-btn {
  background: var(--c-cta);                    /* 加深橙底，白字 AA 4.62:1 */
}

.guide-title {
  display: block;
  font-size: var(--fs-title-sm);               /* 18px */
  font-weight: var(--fw-semibold);
  color: var(--c-title);
}

.guide-desc {
  display: block;
  margin-top: 12rpx;                           /* 6px */
  font-size: var(--fs-body-sm);
  color: var(--c-sub);
}

.result-title {
  display: block;
  font-size: var(--fs-subtitle);               /* 16px */
  font-weight: var(--fw-semibold);
  color: var(--c-title);
}

.result-score {
  display: block;
  margin-top: var(--sp-1);                     /* 4px */
  font-size: var(--fs-body-sm);
  color: var(--c-sub);
}

.result-grid {
  display: flex;
  gap: 20rpx;                                  /* 10px */
  margin-top: 28rpx;                           /* 14px */
}

.result-item {
  flex: 1;
  text-align: center;
  padding: var(--sp-3) 0;                      /* 12px 0 */
  background: var(--c-panel);                  /* #f5f7f6 */
  border-radius: var(--radius-lg);             /* 10px */
}

.result-num {
  display: block;
  font-size: var(--fs-h-xl);                   /* 26px */
  font-weight: var(--fw-bold);
  color: var(--c-primary);
}

.result-label {
  display: block;
  margin-top: var(--sp-1);                     /* 4px */
  font-size: var(--fs-caption);                /* 11px */
  color: var(--c-sub);
}
