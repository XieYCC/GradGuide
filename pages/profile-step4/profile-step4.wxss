.page-profile-step {
  padding: 24px 16px 96px;
  min-height: 100vh;
  background: #fff;
  display: flex;
  flex-direction: column;
}
.profile-step-header {
  margin-bottom: 24px;
}
.profile-step-num {
  font-size: 12px;
  color: var(--c-primary);
  font-weight: 600;
  display: block;
  margin-bottom: 8px;
}
.profile-step-title {
  font-size: 22px;
  font-weight: 700;
  color: var(--c-ink);
  display: block;
}
.profile-step-desc {
  font-size: 12px;
  color: var(--c-ink-3);
  margin-top: 4px;
  display: block;
}
.profile-step-form {
  flex: 1;
}
.profile-section-block {
  margin-bottom: 24px;
}
.profile-sub-label {
  font-size: 13px;
  font-weight: 600;
  color: var(--c-ink);
  display: block;
  margin-bottom: 8px;
}
.profile-item {
  display: flex;
  gap: 8px;
  margin-bottom: 8px;
  align-items: center;
}
.profile-item .profile-input {
  flex: 1;
}
.profile-input {
  padding: 10px;
  border: 1px solid var(--c-line);
  border-radius: 8px;
  font-size: 14px;
}
.profile-picker {
  padding: 10px;
  border: 1px solid var(--c-line);
  border-radius: 8px;
  font-size: 13px;
  color: var(--c-ink-2);
  display: block;
  white-space: nowrap;
}
.profile-add {
  font-size: 12px;
  color: var(--c-primary);
  padding: 4px 0;
  display: inline-block;
}
.profile-step-footer {
  position: fixed;
  left: 0;
  right: 0;
  bottom: 0;
  z-index: 10;
  display: flex;
  gap: 8px;
  padding: 12px 16px calc(12px + env(safe-area-inset-bottom));
  background: #fff;
  border-top: 1px solid var(--c-line);
  box-sizing: border-box;
}
.profile-step-footer .btn {
  flex: 1;
}
