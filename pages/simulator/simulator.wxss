/* 提升模拟器样式 */

.sim-header {
  padding: var(--sp-6) var(--sp-4) var(--sp-2);
}

.sim-header-sub {
  font-size: var(--fs-subtitle);
  font-weight: var(--fw-regular);
  color: var(--c-ink-3);
}

.sim-desc {
  font-size: var(--fs-body-sm);
  color: var(--c-ink-3);
  display: block;
  margin-top: var(--sp-1);
}

.sim-grid {
  padding: 0 var(--sp-4);
  display: flex;
  flex-direction: column;
  gap: var(--sp-4);
  margin-top: var(--sp-4);
}

/* 控制面板 */
.sim-control-card {
  padding: var(--sp-6);
}

.sim-control-title {
  margin-bottom: var(--sp-5);
  display: flex;
  align-items: center;
  gap: var(--sp-1);
}

.sim-slider-group {
  margin-bottom: var(--sp-5);
}

.sim-slider-head {
  display: flex;
  justify-content: space-between;
  font-size: var(--fs-body-sm);
  margin-bottom: var(--sp-2);
}

.sim-slider-val {
  color: var(--c-primary);
  font-weight: var(--fw-semibold);
}

.sim-slider-range {
  display: flex;
  justify-content: space-between;
  font-size: var(--fs-caption-xs);
  color: var(--c-ink-3);
  margin-top: 4rpx;
}

.sim-divider {
  height: 2rpx;
  background: var(--c-line);
  margin: var(--sp-2) 0;
}

.sim-boost-title {
  font-size: var(--fs-body-sm);
  font-weight: var(--fw-semibold);
  color: var(--c-ink);
  display: block;
  margin-bottom: var(--sp-3);
}

.sim-boost-list {
  display: flex;
  flex-direction: column;
  gap: var(--sp-2);
}

.sim-boost-item {
  display: flex;
  align-items: center;
  gap: var(--sp-2);
  padding: var(--sp-3);
  border-radius: var(--radius-md);
  border: var(--border-1) solid var(--c-line);
}

.sim-boost-check {
  width: 40rpx;
  height: 40rpx;
  border-radius: var(--radius-xs);
  border: var(--border-input) solid var(--c-line);
  display: flex;
  align-items: center;
  justify-content: center;
  font-size: var(--fs-body-md);
  color: var(--gg-white);
  flex-shrink: 0;
}
.sim-boost-check-on {
  background: var(--c-primary);
  border-color: var(--c-primary);
}

.sim-boost-content {
  flex: 1;
}

.sim-boost-name {
  font-size: var(--fs-body-sm);
  font-weight: var(--fw-semibold);
  color: var(--c-ink);
  display: block;
}

.sim-boost-impact {
  font-size: var(--fs-caption-xs);
  color: var(--c-ink-3);
  display: block;
  margin-top: 4rpx;
}

.sim-reset-btn {
  width: 100%;
  margin-top: var(--sp-4);
  padding: var(--sp-2);
  border-radius: var(--radius-md);
  border: var(--border-1) solid var(--c-line);
  background: transparent;
  font-size: var(--fs-body-sm);
  color: var(--c-ink-2);
  text-align: center;
}

/* 学校池 */
.sim-pool-card {
  padding: var(--sp-6);
}

.sim-pool-title {
  margin-bottom: var(--sp-4);
  display: flex;
  align-items: center;
  gap: var(--sp-1);
}

.sim-pool-grid {
  display: flex;
  gap: var(--sp-3);
}

.sim-pool-item {
  flex: 1;
  border-radius: var(--radius-md);
  padding: var(--sp-4);
}

.sim-pool-reach {
  background: var(--c-primary-l);
}

.sim-pool-match {
  background: var(--c-accent-l);
}

.sim-pool-safe {
  background: var(--c-surface);
}

.sim-pool-label {
  font-size: var(--fs-caption-xs);
  font-weight: var(--fw-semibold);
  display: block;
}

.sim-pool-reach .sim-pool-label { color: var(--c-primary); }
.sim-pool-match .sim-pool-label { color: var(--c-tier-match-fg); }
.sim-pool-safe .sim-pool-label { color: var(--c-ink); }

.sim-pool-num-row {
  margin-top: var(--sp-1);
}

.sim-pool-num {
  font-size: var(--fs-display-lg);
  font-weight: var(--fw-semibold);
}

.sim-pool-reach .sim-pool-num { color: var(--c-primary); }
.sim-pool-match .sim-pool-num { color: var(--c-tier-match-fg); }
.sim-pool-safe .sim-pool-num { color: var(--c-ink); }

.sim-pool-unit {
  font-size: var(--fs-caption-xs);
  color: var(--c-ink-3);
  display: block;
  margin-top: var(--sp-1);
}

.sim-unlocked {
  margin-top: var(--sp-5);
  padding: var(--sp-4);
  background: var(--c-surface);
  border-radius: var(--radius-md);
}

.sim-unlocked-title {
  font-size: var(--fs-body-sm);
  font-weight: var(--fw-semibold);
  display: block;
  margin-bottom: var(--sp-2);
  display: flex;
  align-items: center;
  gap: var(--sp-1);
}

.sim-unlocked-tags {
  display: flex;
  flex-wrap: wrap;
  gap: var(--sp-2);
}

.sim-unlocked-tag {
  padding: var(--sp-1) var(--sp-2);
  border-radius: var(--radius-full);
  background: var(--c-primary-l);
  color: var(--c-primary);
  font-size: var(--fs-caption-xs);
  font-weight: var(--fw-semibold);
}

.sim-unlocked-empty {
  font-size: var(--fs-caption-xs);
  color: var(--c-ink-3);
  display: block;
}

/* 综合评分 */
.sim-score-card {
  padding: var(--sp-6);
  margin-bottom: var(--sp-4);
}

.sim-score-title {
  margin-bottom: var(--sp-3);
}

.sim-score-body {
  display: flex;
  align-items: center;
  gap: var(--sp-3);
}

.sim-score-bar-wrap {
  flex: 1;
}

.sim-score-labels {
  display: flex;
  justify-content: space-between;
  font-size: var(--fs-caption-xs);
  color: var(--c-ink-3);
  margin-bottom: var(--sp-1);
}

.sim-score-new {
  color: var(--c-primary);
  font-weight: var(--fw-bold);
}

.sim-score-bar {
  height: 24rpx;
  background: var(--c-surface);
  border-radius: var(--radius-full);
  position: relative;
  overflow: hidden;
}

.sim-score-bar-bg {
  position: absolute;
  height: 100%;
  background: var(--c-line);
  border-radius: var(--radius-full);
}

.sim-score-bar-fill {
  position: absolute;
  height: 100%;
  background: var(--c-primary);
  border-radius: var(--radius-full);
  transition: width var(--dur-slow) var(--ease-out);
}

.sim-score-delta {
  font-size: var(--fs-body-sm);
  font-weight: var(--fw-semibold);
  white-space: nowrap;
}

.sim-score-actions {
  margin-top: var(--sp-4);
  display: flex;
  flex-direction: column;
  gap: var(--sp-2);
}

.sim-save-btn {
  font-size: var(--fs-body-sm);
  padding: 20rpx;
}

.sim-history-btn {
  font-size: var(--fs-caption);
  padding: var(--sp-2);
  width: 100%;
}

/* 历史记录 */
.sim-history-card {
  padding: var(--sp-6);
}

.sim-history-title {
  margin-bottom: var(--sp-3);
}

.sim-history-empty {
  padding: var(--sp-4);
  text-align: center;
  font-size: var(--fs-body-sm);
  color: var(--c-ink-3);
  background: var(--c-surface);
  border-radius: var(--radius-md);
}

.sim-history-item {
  display: flex;
  justify-content: space-between;
  align-items: center;
  padding: var(--sp-3);
  border-bottom: var(--border-1) solid var(--c-line);
}

.sim-history-item:last-child {
  border-bottom: none;
}

.sim-history-time {
  font-size: var(--fs-caption-xs);
  color: var(--c-ink-3);
  display: block;
  margin-bottom: 4rpx;
}

.sim-history-score-row {
  display: flex;
  gap: var(--sp-2);
  font-size: var(--fs-body-sm);
  color: var(--c-ink);
}

.sim-history-score {
  font-weight: var(--fw-semibold);
  color: var(--c-primary);
}

.sim-history-tier {
  color: var(--c-ink-2);
}

.sim-history-actions {
  display: flex;
  gap: var(--sp-3);
}

.sim-history-load {
  font-size: var(--fs-caption);
  color: var(--c-primary);
  font-weight: var(--fw-semibold);
}

.sim-history-del {
  font-size: var(--fs-caption);
  color: var(--c-down-fg);
}

.sim-delta-up { color: var(--c-accent); }
.sim-delta-down { color: var(--c-down-fg); }
.sim-delta-zero { color: var(--c-ink-3); }

/* TODO 报告 - 免费 */
.sim-todo-card {
  padding: var(--sp-6);
  border: var(--border-2) solid var(--c-primary);
  position: relative;
}

.sim-todo-header {
  display: flex;
  align-items: center;
  gap: var(--sp-2);
  margin-bottom: var(--sp-2);
}

.sim-todo-desc {
  font-size: var(--fs-body-sm);
  color: var(--c-ink-3);
  display: block;
  margin-bottom: var(--sp-5);
}

.sim-todo-section {
  margin-bottom: var(--sp-5);
}

.sim-todo-section-title {
  font-size: var(--fs-body-sm);
  font-weight: var(--fw-semibold);
  color: var(--c-primary);
  display: block;
  margin-bottom: var(--sp-2);
}

.sim-todo-list {
  display: flex;
  flex-direction: column;
  gap: var(--sp-2);
}

.sim-todo-item {
  display: flex;
  align-items: flex-start;
  gap: var(--sp-2);
  font-size: var(--fs-body-sm);
  color: var(--c-ink);
}

.sim-todo-text {
  flex: 1;
}

.sim-todo-meta {
  font-size: var(--fs-caption-xs);
  color: var(--c-ink-3);
  display: block;
  margin-top: 4rpx;
}

.sim-todo-done {
  text-decoration: line-through;
  color: var(--c-ink-3);
}

.sim-todo-loading {
  text-align: center;
  padding: var(--sp-6);
  font-size: var(--fs-body-sm);
  color: var(--c-ink-3);
}

.sim-todo-empty {
  display: block;
  font-size: var(--fs-caption);
  color: var(--c-ink-3);
  padding: var(--sp-2) 0;
}

/* 顾问 */
.sim-consult-card {
  padding: var(--sp-6);
}

.sim-consult-body {
  display: flex;
  gap: var(--sp-4);
}

.sim-consult-icon {
  width: 112rpx;
  height: 112rpx;
  border-radius: var(--radius-md);
  background: var(--c-accent-l);
  display: flex;
  align-items: center;
  justify-content: center;
  font-size: var(--fs-h-lg);
  flex-shrink: 0;
}

.sim-consult-text {
  flex: 1;
}

.sim-consult-head {
  display: flex;
  align-items: center;
  gap: var(--sp-2);
  margin-bottom: var(--sp-1);
}

.sim-consult-title {
  font-size: var(--fs-subtitle);
  font-weight: var(--fw-semibold);
  color: var(--c-ink);
}

.sim-consult-desc {
  font-size: var(--fs-body-sm);
  color: var(--c-ink-3);
  display: block;
}

.sim-consult-tags {
  display: flex;
  flex-wrap: wrap;
  gap: var(--sp-2);
  margin-top: var(--sp-2);
}

.sim-consult-btn {
  margin-top: var(--sp-3);
}

.sim-pool-delta { font-size: var(--fs-body-sm); font-weight: var(--fw-semibold); }
.sim-pool-delta.up { color: var(--c-accent); }
.sim-pool-delta.down { color: var(--c-down-fg); }
.sim-diff-total { display: block; margin-top: var(--sp-2); font-size: var(--fs-body); font-weight: var(--fw-semibold); color: var(--c-ink); }

/* 模拟操作按钮行 */
.sim-action-row {
  display: flex;
  gap: 20rpx;
  margin-top: var(--sp-4);
  margin-bottom: var(--sp-4);
}
.sim-btn-start {
  flex: 1;
}
.sim-btn-reset {
  width: auto;
  min-width: 160rpx;
  flex-shrink: 0;
}

/* 历史记录名称 */
.sim-history-name {
  font-size: var(--fs-body);
  font-weight: var(--fw-semibold);
  color: var(--c-ink);
  display: block;
  margin-bottom: 4rpx;
}

/* 保存命名弹窗 */
.sim-save-modal {
  position: fixed;
  top: 0; left: 0; right: 0; bottom: 0;
  z-index: var(--z-modal);
  display: flex;
  align-items: center;
  justify-content: center;
}
.sim-save-modal-mask {
  position: absolute;
  top: 0; left: 0; right: 0; bottom: 0;
  background: var(--c-mask);
  animation: mask-in var(--dur-base) var(--ease-out) both;
}
.sim-save-modal-body {
  position: relative;
  width: var(--width-modal);
  background: var(--c-card);
  border-radius: var(--radius-modal);
  padding: var(--pad-card-hero);
  box-shadow: var(--shadow-modal);
  z-index: 1;
  animation: modal-in var(--dur-base) var(--ease-out) both;
}
@keyframes mask-in {
  from { opacity: 0; }
  to { opacity: 1; }
}
@keyframes modal-in {
  from { opacity: 0; transform: scale(0.92); }
  to { opacity: 1; transform: scale(1); }
}
.sim-save-modal-title {
  display: block;
  font-size: var(--fs-title-sm);
  font-weight: var(--fw-bold);
  color: var(--c-ink);
  margin-bottom: var(--sp-4);
  text-align: center;
}
.sim-save-modal-input {
  width: 100%;
  padding: var(--pad-field);
  border: var(--border-1) solid var(--c-line);
  border-radius: var(--radius-field);
  font-size: var(--fs-body-md);
  height: var(--height-field);
  line-height: var(--height-field);
  box-sizing: border-box;
  margin-bottom: var(--sp-5);
}
.sim-save-modal-actions {
  display: flex;
  gap: var(--sp-3);
}
.sim-save-modal-actions .btn {
  flex: 1;
}
