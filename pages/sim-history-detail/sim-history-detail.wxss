.page-history-detail {
  padding: var(--sp-4);
  min-height: 100vh;
  background: var(--c-surface);
}

/* 绿色概览框（从 match 页复制，页面 wxss 不跨页生效） */
.overview-card {
  background: var(--c-primary);
  border-radius: var(--radius-card-hero);
  padding: var(--pad-card-hero);
  margin-bottom: var(--sp-4);
  color: var(--gg-white);
  box-shadow: var(--shadow-card-up);
}
.overview-top {
  display: flex;
  justify-content: space-between;
  flex-wrap: wrap;
  gap: var(--sp-4);
}
.overview-tag {
  font-size: var(--fs-body-sm);
  color: var(--c-white-a70);
}
.overview-title {
  font-size: var(--fs-h-md);
  font-weight: var(--fw-semibold);
  line-height: 1.25;
  margin-top: var(--sp-2);
}
.overview-count {
  color: var(--gg-green-200);
}
.overview-meta {
  margin-top: var(--sp-2);
  font-size: var(--fs-body-sm);
  color: var(--c-white-a80);
  display: flex;
  flex-wrap: wrap;
  gap: var(--sp-3);
}
.overview-stats {
  display: flex;
  gap: var(--sp-6);
}
.overview-stat {
  text-align: center;
}
.overview-stat-num {
  font-size: var(--fs-display-lg);
  font-weight: var(--fw-semibold);
  color: var(--gg-white);
  display: block;
}
.overview-stat-label {
  font-size: var(--fs-caption-xs);
  color: var(--c-white-a60);
  display: block;
  margin-top: var(--sp-1);
}

.history-detail-header {
  padding: var(--sp-4);
  background: var(--c-card);
  border-radius: var(--radius-xl);
  border: var(--border-1) solid var(--c-line);
  margin-bottom: var(--sp-4);
}
.history-detail-name {
  font-size: var(--fs-title-sm);
  font-weight: var(--fw-bold);
  color: var(--c-ink);
  display: block;
}
.history-detail-time {
  font-size: var(--fs-caption);
  color: var(--c-ink-3);
  display: block;
  margin-top: var(--sp-1);
}
.history-detail-score {
  font-size: var(--fs-body);
  color: var(--c-primary);
  font-weight: var(--fw-semibold);
  display: block;
  margin-top: 12rpx;
}
.history-detail-empty {
  display: block;
  text-align: center;
  padding: var(--sp-10);
  font-size: var(--fs-body-md);
  color: var(--c-ink-3);
}

/* 三档 */
.tier-section { margin-bottom: var(--sp-6); }
.tier-header { display: flex; align-items: center; gap: var(--sp-2); margin-bottom: var(--sp-3); }
.tier-title { font-size: var(--fs-subtitle); font-weight: var(--fw-semibold); color: var(--c-ink); }
.tier-grid { display: flex; flex-direction: column; gap: var(--sp-3); }

/* 项目卡片（从 match 页复制，页面 wxss 不跨页生效） */
.program-card {
  padding: var(--sp-5);
}
.program-top {
  display: flex;
  justify-content: space-between;
  gap: var(--sp-3);
  margin-bottom: var(--sp-3);
}
.program-school {
  font-size: var(--fs-body);
  font-weight: var(--fw-semibold);
  color: var(--c-ink);
  display: block;
}
.program-rank {
  font-size: var(--fs-caption-xs);
  color: var(--c-ink-3);
  display: block;
  margin-top: 4rpx;
}
.program-tier-badge {
  font-size: var(--fs-caption-xs);
  font-weight: var(--fw-semibold);
  padding: var(--sp-1) var(--sp-2);
  border-radius: var(--radius-full);
  white-space: nowrap;
  display: flex;
  align-items: center;
  justify-content: center;
  align-self: flex-start;
}
.tier-badge-reach { background: var(--c-primary-l); color: var(--c-primary); }
.tier-badge-match { background: var(--c-accent-l); color: var(--c-tier-match-fg); }
.tier-badge-safety { background: var(--c-surface); color: var(--c-ink-2); }

.program-details {
  display: flex;
  flex-wrap: wrap;
  gap: var(--sp-1);
  margin-bottom: var(--sp-2);
}
.program-detail-item {
  width: calc(50% - 4rpx);
  font-size: var(--fs-caption-xs);
  color: var(--c-ink-3);
  text-align: center;
  padding: var(--sp-1) 0;
  background: var(--c-surface);
  border-radius: var(--radius-sm);
  box-sizing: border-box;
}

/* 推荐理由 / 风险 */
.program-reasons {
  display: flex;
  flex-direction: column;
  gap: var(--sp-1);
  margin-top: var(--sp-2);
}
.program-reason {
  font-size: var(--fs-caption);
  color: var(--c-tier-match-fg);
  background: var(--c-accent-l);
  padding: var(--sp-1) var(--sp-2);
  border-radius: var(--radius-sm);
}
.program-risks {
  display: flex;
  flex-direction: column;
  gap: var(--sp-1);
  margin-top: var(--sp-2);
}
.program-risk {
  font-size: var(--fs-caption);
  color: var(--c-down-fg);
  background: var(--c-down-bg);
  padding: var(--sp-1) var(--sp-2);
  border-radius: var(--radius-sm);
}
