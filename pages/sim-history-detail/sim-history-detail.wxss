.page-history-detail {
  padding: 16px;
  min-height: 100vh;
  background: var(--c-surface);
}

/* 绿色概览框（从 match 页复制，页面 wxss 不跨页生效） */
.overview-card {
  background: var(--c-primary);
  border-radius: 16px;
  padding: 24px;
  margin-bottom: 16px;
  color: #fff;
}
.overview-top {
  display: flex;
  justify-content: space-between;
  flex-wrap: wrap;
  gap: 16px;
}
.overview-tag {
  font-size: 12px;
  color: rgba(255,255,255,0.7);
}
.overview-title {
  font-size: 22px;
  font-weight: 600;
  line-height: 1.25;
  margin-top: 8px;
}
.overview-count {
  color: #9fe3bb;
}
.overview-meta {
  margin-top: 8px;
  font-size: 12px;
  color: rgba(255,255,255,0.8);
  display: flex;
  flex-wrap: wrap;
  gap: 12px;
}
.overview-stats {
  display: flex;
  gap: 24px;
}
.overview-stat {
  text-align: center;
}
.overview-stat-num {
  font-size: 30px;
  font-weight: 600;
  color: #fff;
  display: block;
}
.overview-stat-label {
  font-size: 10px;
  color: rgba(255,255,255,0.6);
  display: block;
  margin-top: 4px;
}

.history-detail-header {
  padding: 16px;
  background: #fff;
  border-radius: 12px;
  border: 1px solid var(--c-line);
  margin-bottom: 16px;
}
.history-detail-name {
  font-size: 18px;
  font-weight: 700;
  color: var(--c-ink);
  display: block;
}
.history-detail-time {
  font-size: 11px;
  color: var(--c-ink-3);
  display: block;
  margin-top: 4px;
}
.history-detail-score {
  font-size: 13px;
  color: var(--c-primary);
  font-weight: 600;
  display: block;
  margin-top: 6px;
}
.history-detail-empty {
  display: block;
  text-align: center;
  padding: 40px;
  font-size: 14px;
  color: var(--c-ink-3);
}

/* 三档 */
.tier-section { margin-bottom: 24px; }
.tier-header { display: flex; align-items: center; gap: 8px; margin-bottom: 12px; }
.tier-title { font-size: 16px; font-weight: 600; color: var(--c-ink); }
.tier-grid { display: flex; flex-direction: column; gap: 12px; }

/* 项目卡片（从 match 页复制，页面 wxss 不跨页生效） */
.program-card {
  padding: 20px;
}
.program-top {
  display: flex;
  justify-content: space-between;
  gap: 12px;
  margin-bottom: 12px;
}
.program-school {
  font-size: 13px;
  font-weight: 600;
  color: var(--c-ink);
  display: block;
}
.program-rank {
  font-size: 10px;
  color: var(--c-ink-3);
  display: block;
  margin-top: 2px;
}
.program-tier-badge {
  font-size: 10px;
  font-weight: 600;
  padding: 4px 8px;
  border-radius: 999px;
  white-space: nowrap;
  display: flex;
  align-items: center;
  justify-content: center;
  align-self: flex-start;
}
.tier-badge-reach { background: var(--c-primary-l); color: var(--c-primary); }
.tier-badge-match { background: var(--c-accent-l); color: #2f7d4d; }
.tier-badge-safety { background: var(--c-surface); color: var(--c-ink-2); }

.program-details {
  display: flex;
  flex-wrap: wrap;
  gap: 4px;
  margin-bottom: 8px;
}
.program-detail-item {
  width: calc(50% - 2px);
  font-size: 10px;
  color: var(--c-ink-3);
  text-align: center;
  padding: 4px 0;
  background: var(--c-surface);
  border-radius: 6px;
  box-sizing: border-box;
}

/* 推荐理由 / 风险 */
.program-reasons {
  display: flex;
  flex-direction: column;
  gap: 4px;
  margin-top: 8px;
}
.program-reason {
  font-size: 11px;
  color: #2f7d4d;
  background: var(--c-accent-l);
  padding: 4px 8px;
  border-radius: 6px;
}
.program-risks {
  display: flex;
  flex-direction: column;
  gap: 4px;
  margin-top: 8px;
}
.program-risk {
  font-size: 11px;
  color: #b4633a;
  background: #f6e3d8;
  padding: 4px 8px;
  border-radius: 6px;
}
