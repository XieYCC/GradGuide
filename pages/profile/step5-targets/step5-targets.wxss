@import "/styles/profile-step.wxss";

/* step5: 目标地区/专业 (chip 多选) + 优先级 picker。
   表单原语已在共享文件，本页仅定义 chip 与宽 picker。 */

.profile-chip-group {
  display: flex;
  flex-wrap: wrap;
  gap: var(--sp-2);
}
.profile-chip {
  padding: var(--sp-2) var(--sp-4);
  border-radius: var(--radius-full);
  border: var(--border-1) solid var(--c-line);
  font-size: var(--fs-body);
  color: var(--c-ink-2);
}
.chip-active {
  border-color: var(--c-primary);
  background: var(--c-primary-l);
  color: var(--c-primary);
  font-weight: var(--fw-semibold);
}
.profile-picker-wide {
  padding: var(--pad-field);
  border: var(--border-1) solid var(--c-line);
  border-radius: var(--radius-field);
  font-size: var(--fs-body-md);
  color: var(--c-ink-2);
  display: block;
}
