.page-profile-init {
  padding: var(--sp-12) var(--sp-6);
  min-height: 100vh;
  background: var(--c-card);
  box-sizing: border-box;
}
.profile-init-title-wrap {
  text-align: center;
  margin-bottom: var(--sp-10);
}
.profile-init-title {
  display: block;
  font-size: var(--fs-h-lg);
  font-weight: var(--fw-bold);
  color: var(--c-title);
}
.profile-init-desc {
  display: block;
  margin-top: var(--sp-2);
  font-size: var(--fs-body-sm);
  color: var(--c-sub);
}
.avatar-section {
  display: flex;
  flex-direction: column;
  align-items: center;
  margin-bottom: 72rpx;
}
.avatar-btn {
  width: 192rpx;
  height: 192rpx;
  border-radius: var(--radius-pill);
  padding: 0;
  margin: 0;
  background: var(--c-panel);
  border: var(--border-1) solid var(--c-line-soft);
  overflow: hidden;
}
.avatar-btn::after {
  border: none;
}
.avatar-img {
  width: 192rpx;
  height: 192rpx;
  border-radius: var(--radius-pill);
}
.avatar-tip {
  margin-top: var(--sp-3);
  font-size: var(--fs-body-sm);
  color: var(--c-sub);
}
.nickname-section {
  margin-bottom: var(--sp-10);
}
.field-label {
  display: block;
  font-size: var(--fs-body);
  font-weight: var(--fw-semibold);
  color: var(--c-body-2);
  margin-bottom: var(--sp-2);
}
.nickname-input {
  width: 100%;
  height: 96rpx;
  line-height: 96rpx;
  padding: 0 var(--sp-3);
  box-sizing: border-box;
  border: none;                                 /* 移除边框 */
  border-radius: var(--radius-btn);           /* 增大圆角 */
  font-size: var(--fs-subtitle);
  background: var(--c-surface);                /* 用底色替代边框 */
}
.actions {
  display: flex;
  flex-direction: column;
  align-items: center;
  gap: var(--sp-4);
}
.save-btn {
  width: 100%;
  height: 92rpx;
  line-height: 92rpx;
  background: var(--c-primary);
  color: var(--gg-white);
  border-radius: 46rpx;
  font-size: var(--fs-subtitle);
  font-weight: var(--fw-semibold);
  padding: 0;
  border: 0;
}
.save-btn::after {
  border: none;
}
.save-btn[disabled] {
  opacity: 0.45;
}
.skip-btn {
  font-size: var(--fs-body);
  color: var(--c-sub);
  padding: var(--sp-2);
}
