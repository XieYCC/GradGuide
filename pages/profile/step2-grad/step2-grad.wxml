<view class="page-profile-step">
  <view class="profile-step-header">
    <text class="profile-step-num">第 2/5 步</text>
    <text class="profile-step-title">你什么时候毕业？</text>
  </view>
  <view class="profile-step-options">
    <view class="profile-option {{selected === item ? 'option-active' : ''}} stagger-in" hover-class="tap-scale" style="--i:{{index}}" wx:for="{{gradYears}}" wx:key="*this" data-value="{{item}}" bindtap="onSelect">
      <text>{{item}}</text>
    </view>
  </view>
  <view class="profile-step-footer">
    <button class="btn btn-light" bindtap="onPrev">上一步</button>
    <button class="btn btn-primary" bindtap="onNext">下一步</button>
  </view>
</view>
