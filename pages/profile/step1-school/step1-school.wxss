@import "/styles/profile-step.wxss";

/* step1: 单选选项卡 */
.profile-step-header { margin-bottom: var(--sp-8); }   /* 覆写默认 --sp-6 */
.profile-step-footer { gap: var(--sp-3); }             /* 覆写默认 --sp-2 */

.profile-step-options {
  display: flex;
  flex-direction: column;
  gap: var(--sp-3);
  flex: 1;
}
.profile-option {
  padding: var(--sp-4);
  border-radius: var(--radius-card-main);      /* 16px 增大圆角 */
  border: none;                                 /* 移除边框 */
  background: var(--c-surface);                /* 用底色替代边框 */
  font-size: var(--fs-body-lg);
  color: var(--c-ink);
  text-align: center;
}
.option-active {
  border-color: var(--c-primary);
  background: var(--c-primary-l);
  color: var(--c-primary);
  font-weight: var(--fw-semibold);
}
