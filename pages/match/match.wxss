/* 选校匹配样式 */

/* 概览卡 */
.overview-card {
  background: var(--c-primary);
  border-radius: 16px;
  padding: 24px;
  margin: 16px;
  color: #fff;
}

.overview-top {
  display: flex;
  justify-content: space-between;
  flex-wrap: wrap;
  gap: 16px;
}

.overview-tag {
  font-size: 12px;
  color: rgba(255,255,255,0.7);
}

.overview-edit {
  text-decoration: underline;
}

.overview-title {
  font-size: 30px;
  font-weight: 600;
  line-height: 1.25;
  margin-top: 8px;
}

.overview-count {
  color: #9fe3bb;
}

.overview-meta {
  margin-top: 8px;
  font-size: 12px;
  color: rgba(255,255,255,0.8);
  display: flex;
  flex-wrap: wrap;
  gap: 12px;
}

.overview-stats {
  display: flex;
  gap: 24px;
}

.overview-stat {
  text-align: left;
}

.overview-stat-num {
  font-size: 30px;
  font-weight: 600;
  color: #fff;
  display: block;
}

.overview-stat-label {
  font-size: 10px;
  color: rgba(255,255,255,0.6);
  display: block;
  margin-top: 4px;
}

.overview-actions {
  display: flex;
  gap: 8px;
  margin-top: 16px;
  flex-wrap: wrap;
}

.overview-btn-ghost {
  background: rgba(255,255,255,0.1);
  color: #fff;
  border-color: rgba(255,255,255,0.3);
}

/* 筛选栏 */
.filter-bar {
  padding: 12px 16px;
  margin: 0 16px 16px;
  display: flex;
  flex-wrap: wrap;
  gap: 8px;
  align-items: center;
}

.filter-group {
  display: flex;
  align-items: center;
  gap: 4px;
}

.filter-label {
  font-size: 12px;
  color: var(--c-ink-3);
}

.filter-btns {
  display: flex;
  gap: 4px;
}

.filter-btn {
  padding: 4px 10px;
  border-radius: 6px;
  font-size: 12px;
  border: 1px solid var(--c-line);
  color: var(--c-ink-2);
}

.filter-btn-active {
  background: var(--c-primary-l);
  color: var(--c-primary);
  border-color: var(--c-primary);
}

.filter-divider {
  width: 1px;
  height: 20px;
  background: var(--c-line);
}

/* 三档 */
.tier-container {
  padding: 0 16px;
}

.tier-section {
  margin-bottom: 24px;
}

.tier-header {
  display: flex;
  align-items: center;
  gap: 8px;
  margin-bottom: 12px;
}

.tier-title {
  font-size: 16px;
  font-weight: 600;
}

.tier-desc {
  font-size: 12px;
  color: var(--c-ink-3);
}

.tier-grid {
  display: flex;
  flex-direction: column;
  gap: 12px;
}

/* 项目卡片 */
.program-card {
  padding: 20px;
}

.program-top {
  display: flex;
  justify-content: space-between;
  gap: 12px;
  margin-bottom: 12px;
}

.program-school {
  font-size: 13px;
  font-weight: 600;
  color: var(--c-ink);
  display: block;
}

.program-rank {
  font-size: 10px;
  color: var(--c-ink-3);
  display: block;
  margin-top: 2px;
}

.program-tier-badge {
  font-size: 10px;
  font-weight: 600;
  padding: 4px 8px;
  border-radius: 999px;
  white-space: nowrap;
  display: flex;
  align-items: center;
  justify-content: center;
  align-self: flex-start;
}

.tier-badge-reach {
  background: var(--c-primary-l);
  color: var(--c-primary);
}

.tier-badge-match {
  background: var(--c-accent-l);
  color: #2f7d4d;
}

.tier-badge-safety {
  background: var(--c-surface);
  color: var(--c-ink-2);
}

.program-details {
  display: flex;
  flex-wrap: wrap;
  gap: 4px;
  margin-bottom: 8px;
}

.program-detail-item {
  width: calc(50% - 2px);
  font-size: 10px;
  color: var(--c-ink-3);
  text-align: center;
  padding: 4px 0;
  background: var(--c-surface);
  border-radius: 6px;
  box-sizing: border-box;
}

.program-highlight {
  font-size: 10px;
  color: var(--c-ink-3);
  font-style: italic;
  margin-bottom: 12px;
}

.program-footer {
  display: flex;
  justify-content: space-between;
  align-items: center;
  padding-top: 12px;
  border-top: 1px solid var(--c-line);
}

.program-status {
  font-size: 10px;
  display: flex;
  align-items: center;
  gap: 4px;
}

.status-warn {
  color: #b4633a;
}

.status-ok {
  color: var(--c-accent);
}

.program-actions {
  display: flex;
  gap: 8px;
}

.program-action {
  font-size: 10px;
  color: var(--c-ink-3);
}

.action-faved {
  color: #c0392b;
  font-weight: 600;
}

.program-action-detail {
  font-size: 10px;
  background: var(--c-primary-l);
  color: var(--c-primary);
  padding: 4px 8px;
  border-radius: 4px;
}

/* 引流条 */
.cta-card {
  margin: 0 16px 16px;
  padding: 20px;
  display: flex;
  align-items: center;
  justify-content: space-between;
  flex-wrap: wrap;
  gap: 12px;
}

.cta-left {
  display: flex;
  align-items: center;
  gap: 12px;
}

.cta-icon {
  width: 48px;
  height: 48px;
  border-radius: 8px;
  background: var(--c-accent-l);
  display: flex;
  align-items: center;
  justify-content: center;
  font-size: 20px;
}

.cta-title {
  font-size: 16px;
  font-weight: 600;
  color: var(--c-ink);
  display: block;
}

.cta-desc {
  font-size: 10px;
  color: var(--c-ink-3);
  display: block;
  margin-top: 2px;
}
