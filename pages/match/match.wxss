/* 选校匹配样式 */

/* 防止横向滚动 */
.page-match {
  overflow-x: hidden;
}

/* —— 中央 Loading Spinner —— */
.page-loading {
  display: flex;
  flex-direction: column;
  align-items: center;
  justify-content: center;
  height: 60vh;
  gap: 32rpx;
}
.loading-spinner {
  width: 64rpx;
  height: 64rpx;
  border: 4rpx solid var(--c-line);
  border-top-color: var(--c-primary);
  border-radius: 50%;
  animation: spin 0.8s linear infinite;
}
@keyframes spin {
  to { transform: rotate(360deg); }
}
.loading-text {
  font-size: var(--fs-body-sm);
  color: var(--c-ink-3);
}

/* 概览卡 (hero 层) */
.overview-card {
  background: var(--c-primary);
  border-radius: var(--radius-card-hero);
  padding: var(--pad-card-hero);
  margin: var(--sp-4);
  color: var(--gg-white);
  box-shadow: var(--shadow-card-hero);
}

.overview-top {
  display: flex;
  justify-content: space-between;
  flex-wrap: wrap;
  gap: var(--sp-4);
}

.overview-tag {
  font-size: var(--fs-body-sm);
  color: var(--c-white-a70);
}

.overview-edit {
  text-decoration: underline;
}

.overview-title {
  font-size: var(--fs-display-lg);
  font-weight: var(--fw-semibold);
  line-height: 1.25;
  margin-top: var(--sp-2);
}

.overview-count {
  color: var(--gg-green-200);
}

.overview-meta {
  margin-top: var(--sp-2);
  font-size: var(--fs-body-sm);
  color: var(--c-white-a80);
  display: flex;
  flex-wrap: wrap;
  gap: var(--sp-3);
}

.overview-stats {
  display: flex;
  gap: var(--sp-6);
}

.overview-stat {
  text-align: left;
}

.overview-stat-num {
  font-size: var(--fs-display-lg);
  font-weight: var(--fw-semibold);
  color: var(--gg-white);
  display: block;
}

.overview-stat-label {
  font-size: var(--fs-caption-xs);
  color: var(--c-white-a60);
  display: block;
  margin-top: var(--sp-1);
}

.overview-actions {
  display: flex;
  gap: var(--sp-2);
  margin-top: var(--sp-4);
  flex-wrap: wrap;
}

.overview-btn-ghost {
  background: var(--c-white-a10);
  color: var(--gg-white);
  border-color: var(--c-white-a30);
}

/* 筛选栏 */
.filter-bar {
  padding: var(--sp-3) var(--sp-4);
  margin: 0 var(--sp-4) var(--sp-4);
  display: flex;
  flex-wrap: wrap;
  gap: var(--sp-2);
  align-items: center;
}

.filter-group {
  display: flex;
  align-items: center;
  gap: var(--sp-1);
}

.filter-label {
  font-size: var(--fs-body-sm);
  color: var(--c-ink-3);
}

.filter-btns {
  display: flex;
  gap: var(--sp-1);
}

.filter-scroll {
  flex: 1;
  white-space: nowrap;
}

.filter-scroll .filter-btn {
  display: inline-block;
}

.filter-btn {
  padding: var(--sp-1) 20rpx;
  border-radius: var(--radius-md);
  font-size: var(--fs-body-sm);
  border: none;
  background: var(--c-surface);
  color: var(--c-ink-2);
}

.filter-btn-active {
  background: var(--c-primary-l);
  color: var(--c-primary);
  border-color: var(--c-primary);
}

.filter-divider {
  width: 2rpx;
  height: 40rpx;
  background: var(--c-line);
}

/* 三档 */
.tier-container {
  padding: 0 var(--sp-4);
}

.tier-section {
  margin-bottom: 40rpx;
}

.tier-header {
  display: flex;
  align-items: center;
  gap: var(--sp-2);
  margin-bottom: var(--sp-3);
}

.tier-title {
  font-size: var(--fs-subtitle);
  font-weight: var(--fw-semibold);
}

.tier-desc {
  font-size: var(--fs-body-sm);
  color: var(--c-ink-3);
}

.tier-grid {
  display: flex;
  flex-direction: column;
  gap: var(--sp-3);
}

/* 项目卡片 */
.program-card {
  padding: var(--sp-5);
}

.program-top {
  display: flex;
  justify-content: space-between;
  gap: var(--sp-3);
  margin-bottom: var(--sp-3);
}

.program-info {
  min-width: 0;
  flex: 1;
}

.program-school {
  font-size: var(--fs-body);
  font-weight: var(--fw-semibold);
  color: var(--c-ink);
  display: block;
  overflow: hidden;
  text-overflow: ellipsis;
  white-space: nowrap;
}

.program-rank {
  font-size: var(--fs-caption-xs);
  color: var(--c-ink-3);
  display: block;
  margin-top: 4rpx;
}

.program-tier-badge {
  font-size: var(--fs-caption-xs);
  font-weight: var(--fw-semibold);
  padding: var(--sp-1) var(--sp-2);
  border-radius: var(--radius-full);
  white-space: nowrap;
  display: flex;
  align-items: center;
  justify-content: center;
  align-self: flex-start;
}

.tier-badge-reach {
  background: var(--c-primary-l);
  color: var(--c-primary);
}

.tier-badge-match {
  background: var(--c-accent-l);
  color: var(--c-tier-match-fg);
}

.tier-badge-safety {
  background: var(--c-surface);
  color: var(--c-ink-2);
}

.program-details {
  display: flex;
  flex-wrap: wrap;
  gap: var(--sp-1);
  margin-bottom: var(--sp-2);
}

.program-detail-item {
  width: calc(50% - 4rpx);
  font-size: var(--fs-caption-xs);
  color: var(--c-ink-3);
  text-align: center;
  padding: var(--sp-2) 0;
  background: var(--c-surface);
  border-radius: var(--radius-md);
  box-sizing: border-box;
}

.program-highlight {
  font-size: var(--fs-caption-xs);
  color: var(--c-ink-3);
  font-style: italic;
  margin-bottom: var(--sp-3);
  display: -webkit-box;
  -webkit-line-clamp: 2;
  -webkit-box-orient: vertical;
  overflow: hidden;
}

.program-reasons,
.program-risks {
  display: flex;
  flex-wrap: wrap;
  gap: var(--sp-1);
  margin-top: var(--sp-2);
}
.program-reason {
  font-size: var(--fs-caption-xs);
  color: var(--c-tier-match-fg);
  background: var(--c-success-bg);
  padding: 4rpx var(--sp-2);
  border-radius: var(--radius-xs);
}
.program-risk {
  font-size: var(--fs-caption-xs);
  color: var(--c-down-fg);
  background: var(--c-down-bg);
  padding: 4rpx var(--sp-2);
  border-radius: var(--radius-xs);
}

.program-footer {
  display: flex;
  justify-content: space-between;
  align-items: center;
  padding-top: var(--sp-3);
  border-top: var(--border-1) solid var(--c-line);
}

.program-status {
  font-size: var(--fs-caption-xs);
  display: flex;
  align-items: center;
  gap: var(--sp-1);
}

.status-warn {
  color: var(--c-down-fg);
}

.status-ok {
  color: var(--c-accent);
}

.program-actions {
  display: flex;
  align-items: center;
  gap: var(--sp-2);
}

.program-action {
  font-size: var(--fs-caption-xs);
  color: var(--c-ink-3);
}

.action-faved {
  color: var(--c-fav-fg);
  font-weight: var(--fw-semibold);
  animation: heart-pop var(--dur-base) var(--ease-out);
}
@keyframes heart-pop {
  0% { transform: scale(1); }
  40% { transform: scale(1.25); }
  100% { transform: scale(1); }
}

.program-action-detail {
  font-size: var(--fs-caption-xs);
  font-weight: var(--fw-semibold);
  background: var(--c-primary);
  color: var(--gg-white);
  padding: var(--sp-1) var(--sp-4);
  border-radius: var(--radius-full);
  display: inline-flex;
  align-items: center;
  justify-content: center;
  min-height: 48rpx;
  line-height: 1;
}

/* 引流条 */
.cta-card {
  margin: 0 var(--sp-4) var(--sp-4);
  padding: var(--sp-5);
  display: flex;
  align-items: center;
  justify-content: space-between;
  flex-wrap: wrap;
  gap: var(--sp-3);
}

.cta-left {
  display: flex;
  align-items: center;
  gap: var(--sp-3);
}

.cta-icon {
  width: 96rpx;
  height: 96rpx;
  border-radius: var(--radius-card-list);
  background: var(--c-accent-l);
  display: flex;
  align-items: center;
  justify-content: center;
  font-size: var(--fs-title);
}

.cta-title {
  font-size: var(--fs-subtitle);
  font-weight: var(--fw-semibold);
  color: var(--c-ink);
  display: block;
}

.cta-desc {
  font-size: var(--fs-caption-xs);
  color: var(--c-ink-3);
  display: block;
  margin-top: 4rpx;
}
